{
  "name": "connorhunter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "audit": "bun run deps:policy:check && bun audit --audit-level=high",
    "build": "bun x vite build",
    "deps:policy": "bun scripts/dependencies/sync-dependency-policy.ts",
    "deps:policy:check": "bun scripts/dependencies/sync-dependency-policy.ts --check",
    "dev": "bun x vite dev",
    "format": "bun x prettier --write . --ignore-unknown",
    "format:check": "bun x prettier --check . --ignore-unknown",
    "lint": "bun x eslint .",
    "prepare": "bun scripts/git-hooks/setup-git-hooks.ts",
    "start": "node .output/server/index.mjs",
    "test": "bun test --isolate",
    "coverage:build": "bun test --isolate --coverage && bun run coverage:render",
    "coverage:publish": "bun run coverage:build && bun scripts/publish/publish-coverage.ts",
    "coverage:render": "bun scripts/coverage/render-coverage-report.ts",
    "test:coverage": "bun run coverage:build && bun scripts/coverage/check-coverage.ts",
    "typecheck": "bun x tsgo --noEmit -p tsconfig.json",
    "verify": "bun run audit && bun run format && bun run lint && bun run typecheck && bun run test:coverage"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.5",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-start": "^1.168.25",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.18.0",
    "marked": "^18.0.5",
    "motion": "^12.40.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/router-plugin": "^1.168.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260603.1",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.10.3",
    "nitro": "^3.0.260610-beta",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16"
  }
}
